{
    "profile": [
        {
            "input": [
                {
                    "sequence":1,
                    "name":"firstName",
                    "label":"First Name",
                    "type":"text",
                    "required":true,
                    "pattern":"/[A-Za-z]{3,}/g",
                    "display":"inline"
                },
                {
                    "sequence":2,
                    "name":"lastName",
                    "label":"Last Name",
                    "type":"text",
                    "required":true,
                    "pattern":"/[A-Za-z]{3,}/g",
                    "display":"inline"
                },
                {
                    "sequence":3,
                    "name":"title",
                    "label":"title",
                    "type":"text",
                    "required":true,
                    "pattern":"/[A-Za-z]{3,}/g",
                    "display":"inline"
                },
                {
                    "sequence":4,
                    "name":"profile",
                    "label":"Profile",
                    "type":"file",
                    "accept":"image/png, image/jpeg",
                    "required":true,
                    "display":"inline"
                },
                {
                    "sequence":5,
                    "name":"address",
                    "label":"Address",
                    "type":"text",
                    "required":true,
                    "pattern":"/[\\w,\\s]{5,}/g"
                },
                {
                    "sequence":6,
                    "name":"city",
                    "label":"City ",
                    "type":"text",
                    "required":true,
                    "pattern":"/[A-Za-z\\s]+/g",
                    "display":"inline"
                },
                {
                    "sequence":7,
                    "name":"state",
                    "label":"State",
                    "type":"text",
                    "required":true,
                    "pattern":"/[A-Za-z\\s]+/g",
                    "display":"inline"
                },
                {
                    "sequence":8,
                    "name":"zipCode",
                    "label":"Zip Code",
                    "type":"number",
                    "required":true,
                    "pattern":"/(^\\d{6}$)|(^\\d{5}-\\d{4}$)/",
                    "display":"inline"
                },
                {
                    "sequence":9,
                    "name":"email",
                    "label":"Email",
                    "type":"email",
                    "required":true,
                    "pattern":"/^[\\w+@[a-zA-Z_]+?\\.[a-zA-Z]{2,3}$/",
                    "display":"inline"
                },
                {
                    "sequence":10,
                    "name":"phoneNumber",
                    "label":"Phone Number",
                    "type":"number",
                    "required":true,
                    "pattern":"/(^\\d{10}$)/",
                    "display":"inline"
                }
                
            ],
            "button": {}
        }
        ]
    }